package com.chaoscube.screen;

import com.chaoscube.network.ModNetwork;
import net.fabricmc.api.EnvType;
import net.fabricmc.api.Environment;
import net.fabricmc.fabric.api.client.networking.v1.ClientPlayNetworking;
import net.fabricmc.fabric.api.networking.v1.PacketByteBufs;
import net.minecraft.client.gui.DrawContext;
import net.minecraft.client.gui.screen.ingame.HandledScreen;
import net.minecraft.client.gui.widget.ButtonWidget;
import net.minecraft.client.gui.widget.TextFieldWidget;
import net.minecraft.entity.player.PlayerInventory;
import net.minecraft.network.PacketByteBuf;
import net.minecraft.text.Text;

@Environment(EnvType.CLIENT)
public class ChaosCubeScreen extends HandledScreen<ChaosCubeScreenHandler> {

    private TextFieldWidget urlField;
    private ButtonWidget playButton;
    private ButtonWidget stopButton;

    private static final int GUI_W = 256;
    private static final int GUI_H = 110;

    public ChaosCubeScreen(ChaosCubeScreenHandler handler, PlayerInventory inv, Text title) {
        super(handler, inv, title);
        this.backgroundWidth = GUI_W;
        this.backgroundHeight = GUI_H;
    }

    @Override
    protected void init() {
        super.init();
        int x = (width - GUI_W) / 2;
        int y = (height - GUI_H) / 2;

        // URL text field
        urlField = new TextFieldWidget(textRenderer, x + 10, y + 35, GUI_W - 20, 18,
                Text.literal("YouTube URL"));
        urlField.setMaxLength(512);
        urlField.setText(handler.getBlockEntity().getYoutubeUrl());
        urlField.setPlaceholder(Text.literal("https://www.youtube.com/watch?v=..."));
        addSelectableChild(urlField);
        setInitialFocus(urlField);

        // Play button
        playButton = ButtonWidget.builder(Text.literal("▶  PLAY"), btn -> sendUrl(true))
                .dimensions(x + 10, y + 62, 110, 20).build();
        addDrawableChild(playButton);

        // Stop button
        stopButton = ButtonWidget.builder(Text.literal("■  STOP"), btn -> sendUrl(false))
                .dimensions(x + 136, y + 62, 110, 20).build();
        addDrawableChild(stopButton);
    }

    private void sendUrl(boolean play) {
        String url = play ? urlField.getText().trim() : "";
        PacketByteBuf buf = PacketByteBufs.create();
        buf.writeBlockPos(handler.getBlockEntity().getPos());
        buf.writeString(url, 512);
        buf.writeBoolean(play && !url.isEmpty());
        ClientPlayNetworking.send(ModNetwork.SET_URL, buf);
        if (!play) urlField.setText("");
    }

    @Override
    protected void drawBackground(DrawContext ctx, float delta, int mouseX, int mouseY) {
        int x = (width - GUI_W) / 2;
        int y = (height - GUI_H) / 2;

        // Background panel
        ctx.fill(x, y, x + GUI_W, y + GUI_H, 0xE0101018);
        ctx.fill(x + 2, y + 2, x + GUI_W - 2, y + GUI_H - 2, 0xE0141428);

        // Cyan border
        ctx.fill(x,           y,           x + GUI_W, y + 2,      0xFF00BFFF);
        ctx.fill(x,           y + GUI_H-2, x + GUI_W, y + GUI_H,  0xFF00BFFF);
        ctx.fill(x,           y,           x + 2,     y + GUI_H,  0xFF00BFFF);
        ctx.fill(x + GUI_W-2, y,           x + GUI_W, y + GUI_H,  0xFF00BFFF);

        // Cyan corner glow
        ctx.fill(x,           y,           x + 6,     y + 6,      0x8800BFFF);
        ctx.fill(x + GUI_W-6, y,           x + GUI_W, y + 6,      0x8800BFFF);
        ctx.fill(x,           y + GUI_H-6, x + 6,     y + GUI_H,  0x8800BFFF);
        ctx.fill(x + GUI_W-6, y + GUI_H-6, x + GUI_W, y + GUI_H,  0x8800BFFF);

        // Separator line under title
        ctx.fill(x + 8, y + 22, x + GUI_W - 8, y + 23, 0x5500BFFF);

        // Draw URL field background
        ctx.fill(x + 8, y + 33, x + GUI_W - 8, y + 55, 0xFF0a0a18);
        ctx.fill(x + 9, y + 34, x + GUI_W - 9, y + 54, 0xFF050510);

        urlField.render(ctx, mouseX, mouseY, delta);
    }

    @Override
    public void render(DrawContext ctx, int mouseX, int mouseY, float delta) {
        renderBackground(ctx);
        super.render(ctx, mouseX, mouseY, delta);

        int x = (width - GUI_W) / 2;
        int y = (height - GUI_H) / 2;

        // Title
        String title = "✦  CHAOS CUBE  ✦";
        ctx.drawText(textRenderer, title,
                x + GUI_W / 2 - textRenderer.getWidth(title) / 2,
                y + 8, 0x00BFFF, true);

        // "YouTube URL:" label
        ctx.drawText(textRenderer, "YouTube URL:", x + 10, y + 25, 0x8888AA, false);

        // Status indicator
        boolean playing = handler.getBlockEntity().isPlaying();
        String status = playing ? "● PLAYING" : "○ STOPPED";
        int col = playing ? 0x00FF88 : 0xFF5555;
        ctx.drawText(textRenderer, status,
                x + GUI_W - textRenderer.getWidth(status) - 10, y + 8, col, true);

        // Range hint
        ctx.drawText(textRenderer, "Range: 30 blocks  |  Volume follows distance",
                x + 10, y + 90, 0x445566, false);
    }

    @Override
    protected void drawForeground(DrawContext ctx, int mouseX, int mouseY) {
        // Suppress default title/inventory labels
    }

    @Override
    public boolean keyPressed(int keyCode, int scanCode, int modifiers) {
        // Allow Enter to trigger play
        if (keyCode == 257 || keyCode == 335) { // Enter / Numpad Enter
            sendUrl(true);
            return true;
        }
        if (urlField.keyPressed(keyCode, scanCode, modifiers)) return true;
        return super.keyPressed(keyCode, scanCode, modifiers);
    }

    @Override
    public boolean charTyped(char chr, int modifiers) {
        return urlField.charTyped(chr, modifiers) || super.charTyped(chr, modifiers);
    }
}
